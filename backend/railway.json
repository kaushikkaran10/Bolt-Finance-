{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "dockerfile"
  },
  "deploy": {
    "numReplicas": 1,
    "startCommand": "sh -c 'uvicorn main:app --host 0.0.0.0 --port ${PORT:-8000} --workers 2'",
    "healthcheck": {
      "interval": 30,
      "timeout": 10,
      "retries": 3
    }
  }
}
